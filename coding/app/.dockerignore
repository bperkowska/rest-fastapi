# ═══════════════════════════════════════════════════════════
# .dockerignore - Pliki ignorowane podczas docker build
# ═══════════════════════════════════════════════════════════
#
# Dlaczego .dockerignore?
# - Mniejszy build context (szybszy build)
# - Bezpieczeństwo (nie kopiuj secrets do image)
# - Czystość (tylko potrzebne pliki w image)
#
# ═══════════════════════════════════════════════════════════

# Git
.git
.gitignore

# Docker
Dockerfile
docker-compose.yml
.dockerignore

